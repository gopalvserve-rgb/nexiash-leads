{
  "appId": "com.nexiash.leads",
  "appName": "Nexiash CRM",
  "webDir": "www",
  "server": {
    "url": "https://crm.nexusai.co.in/",
    "cleartext": false,
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": [
      "crm.nexusai.co.in",
      "*.nexusai.co.in",
      "nexiash-app-production.up.railway.app",
      "tel:*",
      "mailto:*",
      "whatsapp:*"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0E1A14",
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "CallerId": {
      "enabled": true
    }
  },
  "ios": {
    "backgroundColor": "#0F172A",
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": false,
    "scrollEnabled": true,
    "preferredContentMode": "mobile",
    "scheme": "App"
  }
}
